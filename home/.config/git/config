[user]
    name       = Gary Ash
    email      = gary.ash@icloud.com
	signingkey = /Users/garyash/.ssh/id_ed25519.pub

[gpg "ssh"]
	allowedSignersFile = /Users/garyash/.ssh/allowed_signers


[credential]
	helper = cache --timeout=604800

[github]
	user            = Gary-Ash

[init]
	defaultBranch = main
	templateDir   = ~/.config/git/template

[core]
    excludesfile      = /Users/garyash/.config/git/gitignore
    attributesFile    = ~/.config/git/gitattributes
    autocrlf          = input
    compression       = 9
    filemode          = false
    precomposeUnicode = false
    editor            = subl --wait

[delta]
    true-color   = always
    line-numbers = true
    tabs         = 4
    syntax-theme = Solarized (light)
    side-by-side = true

[pager]
	diff            = delta
	show            = delta

[color]
	ui = true


[protocol]
	version = 2

[color "branch"]
	current         = black
	local           = normal
	remote          = magenta bold

[color "status"]
	added           = green
	changed         = blue
	untracked       = cyan

[alias]
	difft           = "difftool -y"								# use the my external diff tool w/o prompting
	unstage         = "reset HEAD --"         					# unstage the named file(s)
	discard         = "checkout --"           					# undo last commit
	clone           = "clone --recursive"     					# clone submodules too
	log             = "--decorate --graph --all"				# fancy up my log
	fpush  			= "push --force"
	amend			= "commit --amend --reuse-message=HEAD"
	delete-merged   = "git branch --merged | grep -i -v -E \"master|main|develop|dev\"| xargs git branch -d"
	trim 			= "!f() { git branch | grep -v \"main\" | grep -v \"master\" | grep -v \"^*\" | xargs git branch -D; git remote prune rigin; }; f"
	fuckit          = "!git clean -df && git reset --hard"
	gcc 			= "gc --aggressive --cruft"
  	pruner 			= "!git prune --expire=now; git reflog expire --expire-unreachable=now --rewrite --all"


[url "https://github.com/"]
	insteadOf       = gh:

[url "https://gist.github.com/"]
	insteadOf       = gist:

[filter "hawser"]
	clean           = git hawser clean %f
	smudge          = git hawser smudge %f
	required        = true

[filter "lfs"]
	clean           = git-lfs clean -- %f
	smudge          = git-lfs smudge -- %f
	process         = git-lfs filter-process
	required        = true


[gpg]
	format = ssh

[log]
	date = human

[help]
	autocorrect     = 1

[submodule]
    fetchJobs = 0
    recurse   = true

[status]
    showStash        = true
    submodule        = 1
    submoduleSummary = true
   	showuntrackedfiles = all

[push]
	default         = simple
	autoSetupRemote = true
	followTags 		= true

[commit]
    verbose  = true
    gpgSign  = true
    verbose  = true
    template = /Users/garyash/.config/git/gitmessage

[tag]
	sort 	= -v:refname

[fetch]
	prune = true
	writeCommitGraph = true

[gc]
	writeCommitGraph = true

[rebase]
	autosquash = true

[pull]
	ff = only

[diff "utf16"]
	textconv = "iconv -t utf-8"

[diff "plist"]
	textconv = plutil -convert xml1 -o -

[diff "bin"]
	textconv = hexdump -v -C
	binary = true

[diff]
    tool    = Kaleidoscope
    guitool = Kaleidoscope
	submodule = log

[difftool "Kaleidoscope"]
    cmd           = ksdiff --partial-changeset --relative-path \"$MERGED\" -- \"$LOCAL\" \"$REMOTE\"
    prompt        = false
    trustExitCode = true

[merge]
	tool = Kaleidoscope

[mergetool "Kaleidoscope"]
    cmd           = ksdiff --merge --output \"$MERGED\" --base \"$BASE\" -- \"$LOCAL\" --snapshot \"$REMOTE\" --snapshot
    trustExitCode = true
    prompt        = false
