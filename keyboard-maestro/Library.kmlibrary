		<dict>
			<key>Activate</key>
			<string>Normal</string>
			<key>CreationDate</key>
			<real>588380868.02725506</real>
			<key>Macros</key>
			<array>
				<dict>
					<key>Actions</key>
					<array>
						<dict>
							<key>ActionUID</key>
							<integer>5453</integer>
							<key>DisplayKind</key>
							<string>None</string>
							<key>HonourFailureSettings</key>
							<true/>
							<key>IncludeStdErr</key>
							<false/>
							<key>IncludedVariables</key>
							<array>
								<string>9999</string>
							</array>
							<key>MacroActionType</key>
							<string>ExecuteAppleScript</string>
							<key>Path</key>
							<string></string>
							<key>Text</key>
							<string>set finderPath to ""

try
	tell application "Finder"
		if (count of Finder windows) &gt; 0 then
			set finderPath to quoted form of POSIX path of ((target of front Finder window) as text)
		else
			set finderPath to POSIX path of (path to home folder)
		end if
	end tell
end try
tell application "Ghostty"	activateend telltell application "System Events"	set timeoutCounter to 0	set isBannerRunning to true		-- Wait up to 3 seconds for Ghostty to be ready and StartupBanner to clear	repeat until (timeoutCounter &gt; 25)		-- Check if Ghostty is frontmost		set isFrontmost to (frontmost of application process "Ghostty" is true)				-- Check if StartupBanner is still active		set isBannerRunning to (exists application process "StartupBanner")				-- If Ghostty is focused AND the banner is gone, we're good to go		if isFrontmost and not isBannerRunning then exit repeat				delay 0.1		set timeoutCounter to timeoutCounter + 1	end repeat		-- Final safety check before typing	if (frontmost of application process "Ghostty" is true) and (not isBannerRunning) then		keystroke "cd " &amp; finderPath		key code 36 -- The Return/Enter key	else		display notification "Ghostty or StartupBanner check timed out." with title "Script Error"	end ifend tell</string>
