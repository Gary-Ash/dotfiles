							<string></string>
							<key>Text</key>
							<string>my formatDateTimeStamp()on formatDateTimeStamp()	set d to current date		set theDay to day of d	set theMonth to text 1 thru 3 of ((month of d) as text)	set theYear to year of d		set theHour to hours of d	set theMinute to minutes of d		if theHour ≥ 12 then		set suffix to "pm"	else		set suffix to "am"	end if		if theHour = 0 then		set theHour to 12	else if theHour &gt; 12 then		set theHour to theHour - 12	end if		-- Pad values	if theMinute &lt; 10 then		set theMinute tao "0" &amp; theMinute	else		set theMinute to theMinute as text	end if		set theDay to theDay as text	set theHour to theHour as text	set theYear to theYear as text		set formattedDate to theDay &amp; "-" &amp; theMonth &amp; "-" &amp; theYear &amp; "  " &amp; theHour &amp; ":" &amp; theMinute &amp; suffix		return formattedDateend formatDateTimeStamp</string>
							<key>TimeOutAbortsMacro</key>
							<true/>
							<key>TrimResults</key>
							<false/>
							<key>TrimResultsNew</key>
							<false/>
							<key>UseText</key>
							<true/>
						</dict>
